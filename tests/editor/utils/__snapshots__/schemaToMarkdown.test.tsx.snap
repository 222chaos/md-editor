// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`schemaToMarkdown > should correctly convert a basic paragraph to Markdown 1`] = `
"{  
"type": "paragraph",  
"children": [{ "text": "This is a paragraph." }]  
}"
`;

exports[`schemaToMarkdown > should correctly convert lists and list items to Markdown 1`] = `
"[  
{ "type": "list", "children": [  
{ "type": "list-item", "children": [{ "text": "Item 1" }] },  
{ "type": "list-item", "children": [{ "text": "Item 2" }] }  
]  
}  
]"
`;

exports[`schemaToMarkdown > should correctly format a table 1`] = `
"{  
"type": "table",  
"children": [  
{ "type": "table-row", "children": [  
{ "type": "table-cell", "children": [{ "text": "Header 1" }] },  
{ "type": "table-cell", "children": [{ "text": "Header 2" }] }  
]  
},  
{ "type": "table-row", "children": [  
{ "type": "table-cell", "children": [{ "text": "Cell 1" }] },  
{ "type": "table-cell", "children": [{ "text": "Cell 2" }] }  
]  
}  
]  
}"
`;

exports[`schemaToMarkdown > should correctly handle blockquotes 1`] = `
"{  
"type": "blockquote",  
"children": [{ "text": "This is a quote." }]  
}"
`;

exports[`schemaToMarkdown > should correctly handle headings of various levels 1`] = `
"[  
{ "type": "head", "level": 1, "children": [{ "text": "Heading 1" }] },  
{ "type": "head", "level": 2, "children": [{ "text": "Heading 2" }] }  
]"
`;

exports[`schemaToMarkdown > should correctly handle media nodes like images and videos 1`] = `
"[  
{ "type": "media", "url": "[https://example.com/image.jpg](https://example.com/image.jpg)", "alt": "Example Image", "height": 200 },  
{ "type": "media", "url": "[https://example.com/video.mp4](https://example.com/video.mp4)", "height": 300 }  
]"
`;

exports[`schemaToMarkdown > should handle code blocks with different languages 1`] = `
"{  
"type": "code",  
"language": "javascript",  
"children": [{ "children": [{ "text": "console.log('Hello, world!');" }] }]  
}"
`;

exports[`schemaToMarkdown > should handle horizontal rules and line breaks 1`] = `
"[  
{ "type": "hr" },  
{ "type": "break" }  
]"
`;

exports[`schemaToMarkdown > should handle links and link-cards correctly 1`] = `
"[  
{ "type": "link-card", "url": "[https://example.com](https://example.com)", "name": "Example Site" },  
{ "type": "paragraph", "children": [{ "type": "link", "url": "[https://example.com](https://example.com)", "children": [{ "text": "Example Link" }] }] }  
]"
`;
